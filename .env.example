# ── Supabase (REQUIRED) ────────────────────────────────────────────────────────
# Project URL — Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project.supabase.co

# Service role key (NOT the anon key) — full DB access, keep secret
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── AI Providers (REQUIRED for /api/chat) ──────────────────────────────────────
# Anthropic — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini — https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=AIza...

# Groq — https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# MiniMax — https://platform.minimaxi.com
MINIMAX_API_KEY=your-minimax-key

# ── AI Model Overrides (OPTIONAL) ─────────────────────────────────────────────
# Remove the comment to override the default model for each provider.
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# GEMINI_MODEL=gemini-2.5-flash
# MINIMAX_MODEL=MiniMax-M2.5

# ── Server ─────────────────────────────────────────────────────────────────────
# Railway injects PORT automatically — do NOT set this in Railway dashboard.
# For local development the default is 3000.
# PORT=3000
